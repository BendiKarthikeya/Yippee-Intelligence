    {
      "parameters": {
        "jsCode": "// ─── Normalize Twitter API v2 response ───\nconst allItems = $input.all();\n\n// Get keyword from the current loop iteration (paired item)\nconst loopItem = $('Loop Over Keywords1').item.json;\nconst keyword = loopItem?.keyword || '';\nconst config = loopItem?.config || {\n  campaign: { keywords: [], hashtags: ['YippeeNoodles','InstantNoodles','DesiFood'] }\n};\nconst results = [];\n\nfor (const item of allItems) {\n  const responseData = item.json;\n  const tweets = responseData.data || [];\n  const users = {};\n\n  if (responseData.includes?.users) {\n    responseData.includes.users.forEach(u => { users[u.id] = u; });\n  }\n\n  for (const tweet of tweets) {\n    if (!tweet.id || !tweet.text) continue;\n\n    const author = users[tweet.author_id] || {};\n    const username = author.username || '';\n    const authorName = author.name || '';\n    const followers = author.public_metrics?.followers_count || 0;\n    const following = author.public_metrics?.following_count || 0;\n    const verified = author.verified || false;\n    const profileImage = author.profile_image_url || '';\n    const authorBio = author.description || '';\n\n    const likes = tweet.public_metrics?.like_count || 0;\n    const replies = tweet.public_metrics?.reply_count || 0;\n    const retweets = tweet.public_metrics?.retweet_count || 0;\n    const quotes = tweet.public_metrics?.quote_count || 0;\n    const impressions = tweet.public_metrics?.impression_count || 0;\n    const bookmarks = tweet.public_metrics?.bookmark_count || 0;\n    const total_eng = likes + replies + retweets + quotes;\n    const eng_rate = followers > 0 ? parseFloat((total_eng / followers * 100).toFixed(2)) : 0;\n\n    const text = tweet.text || '';\n    const hashtags = (tweet.entities?.hashtags || []).map(h => h.tag).join(', ');\n    const mentions = (tweet.entities?.mentions || []).map(m => m.username).join(', ');\n    const urls = (tweet.entities?.urls || []).map(u => u.expanded_url).join(', ');\n\n    const posted = tweet.created_at || new Date().toISOString();\n    const postedDate = new Date(posted);\n    const tweetUrl = username ? `https://x.com/${username}/status/${tweet.id}` : '';\n\n    const kw_hits = (config.campaign?.keywords || []).filter(k =>\n      text.toLowerCase().includes(k.toLowerCase())\n    ).length;\n    const ht_hits = (tweet.entities?.hashtags || []).map(h => h.tag || '').filter(h =>\n      (config.campaign?.hashtags || []).includes(h)\n    ).length;\n    const maxRelevance = (config.campaign?.keywords?.length || 1) * 0.4 + (config.campaign?.hashtags?.length || 1) * 0.3 + 0.001;\n    const relevance = parseFloat(((kw_hits * 0.4 + ht_hits * 0.3) / maxRelevance).toFixed(4));\n    const virality = parseFloat((Math.log10(likes + 2 * retweets + 3 * replies + 1) / Math.log10(followers + 2)).toFixed(4));\n    const influence = parseFloat((Math.log10(followers + 1) * eng_rate / 100).toFixed(4));\n    const composite = parseFloat((virality * 0.4 + relevance * 0.35 + influence * 0.25).toFixed(4));\n\n    const tier = followers > 1000000 ? 'macro' : followers > 100000 ? 'mid' : followers > 10000 ? 'micro' : 'nano';\n\n    results.push({\n      json: {\n        platform: 'twitter',\n        post_id: tweet.id,\n        tweet_url: tweetUrl,\n        author_username: username,\n        author_name: authorName,\n        author_followers: followers,\n        author_following: following,\n        author_verified: verified,\n        author_bio: authorBio.substring(0, 200),\n        author_profile_image: profileImage,\n        influencer_tier: tier,\n        text: text.substring(0, 500),\n        hashtags, mentions,\n        urls_in_tweet: urls,\n        media_type: tweet.attachments?.media_keys ? 'media' : 'none',\n        likes, replies, retweets, quotes, bookmarks, impressions,\n        total_engagement: total_eng,\n        engagement_rate: eng_rate,\n        posted_at: posted,\n        hour_of_day: postedDate.getUTCHours(),\n        day_of_week: ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][postedDate.getUTCDay()],\n        is_weekend: [0, 6].includes(postedDate.getUTCDay()),\n        language: tweet.lang || '',\n        relevance_score: relevance,\n        virality_score: virality,\n        influence_score: influence,\n        composite_rank: composite,\n        search_keyword: keyword,\n        scraped_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\n// Dedup by post_id and add global_rank\nconst seen = new Set();\nconst deduped = results.filter(r => {\n  if (seen.has(r.json.post_id)) return false;\n  seen.add(r.json.post_id);\n  return true;\n}).sort((a, b) => b.json.composite_rank - a.json.composite_rank);\ndeduped.forEach((r, idx) => { r.json.global_rank = idx + 1; });\n\nreturn deduped.length > 0 ? deduped : [{ json: { error: true, message: 'No tweets matched filters', scraped_at: new Date().toISOString() } }];\n"
      },
