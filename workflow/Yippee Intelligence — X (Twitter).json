    {
      "parameters": {
        "jsCode": "// ─── Summary Stats ───\nconst all = $input.all().filter(i => !i.json.error && !i.json.message).map(i => i.json);\nconst total = all.length;\n\nif (total === 0) {\n  return [{ json: { platform: 'twitter', total_posts_captured: 0, message: 'No data to summarize', generated_at: new Date().toISOString() } }];\n}\n\nconst avgComposite = parseFloat((all.reduce((s, r) => s + r.composite_rank, 0) / total).toFixed(4));\n\n// Top influencers\nconst topInfluencers = all.slice(0, 5).map(r => ({\n  username: r.author_username,\n  followers: r.author_followers,\n  engagement: r.total_engagement,\n  composite: r.composite_rank,\n  tweet_url: r.tweet_url\n}));\n\n// Peak hours\nconst hourDist = {};\nall.forEach(r => { hourDist[r.hour_of_day] = (hourDist[r.hour_of_day] || 0) + 1; });\nconst peakHour = Object.entries(hourDist).sort((a, b) => b[1] - a[1])[0];\n\n// Hashtag frequency\nconst hashtagFreq = {};\nall.forEach(r => {\n  (r.hashtags || '').split(', ').filter(Boolean).forEach(h => {\n    hashtagFreq[h] = (hashtagFreq[h] || 0) + 1;\n  });\n});\nconst topHashtags = Object.entries(hashtagFreq).sort((a, b) => b[1] - a[1]).slice(0, 10);\n\n// Tier distribution\nconst tierDist = {};\nall.forEach(r => { tierDist[r.influencer_tier] = (tierDist[r.influencer_tier] || 0) + 1; });\n\n// Weekend vs weekday\nconst weekendCount = all.filter(r => r.is_weekend).length;\n\nreturn [{\n  json: {\n    platform: 'twitter',\n    total_posts_captured: total,\n    avg_composite_rank: avgComposite,\n    peak_posting_hour_utc: peakHour ? parseInt(peakHour[0]) : null,\n    influencer_tier_distribution: tierDist,\n    top_10_hashtags: topHashtags.map(([tag, count]) => ({ tag, count })),\n    weekend_vs_weekday: { weekend: weekendCount, weekday: total - weekendCount },\n    top_5_influencers: topInfluencers,\n    generated_at: new Date().toISOString()\n  }\n}];"
      },
